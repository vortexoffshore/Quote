        "name": { "type": "string" },
        "date": { "type": "string" },
        "version": { "type": "string" },
        "currency": { "type": "string" },
        "generalNotes": { "type": "string" },
        "vendors": { "type": "array" },
        "categories": { "type": "array" },
        "costValues": { "type": "object" },
        "comments": { "type": "object" },
        "vendorNotes": { "type": "object" },
        "criteria": { "type": "array" },
        "uploadedFiles": { "type": "array" }
